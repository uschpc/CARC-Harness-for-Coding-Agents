      "Write(~/.anthropic/**)",
      "Edit(~/.anthropic/**)",
      "Write(~/.claude.json)",
      "Edit(~/.claude.json)",
      "Write(~/.claude/settings.json)",
      "Edit(~/.claude/settings.json)",
      "Write(~/.claude/.credentials.json)",
      "Edit(~/.claude/.credentials.json)",
      "Write(~/.codex/**)",
      "Edit(~/.codex/**)",
      "Write(~/.openai/**)",
      "Edit(~/.openai/**)",
      "Write(~/.config/openai/**)",
