      "Write(~/.config/gemini-cli/**)",
      "Edit(~/.config/gemini-cli/**)",

      "Write(~/.apptainer/**)",
      "Edit(~/.apptainer/**)",
      "Write(~/.singularity/**)",
      "Edit(~/.singularity/**)",
      "Write(~/.gnupg/**)",
      "Edit(~/.gnupg/**)",
      "Write(~/.globus/**)",
