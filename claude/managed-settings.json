      "Read(~/.Rhistory)",
      "Read(~/.lesshst)",
      "Read(~/.Renviron)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.azure/**)",
      "Read(~/.kube/**)",
      "Read(~/.npmrc)",
      "Read(~/.config/gh/**)",
      "Read(~/.kaggle/kaggle.json)",
      "Read(~/.config/containers/auth.json)",
      "Read(~/.terraform.d/credentials.tfrc.json)",

      "Write(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Write(~/.aws/**)",
      "Edit(~/.aws/**)",
      "Write(~/.config/gcloud/**)",
      "Edit(~/.config/gcloud/**)",

      "Write(~/.netrc)",
      "Edit(~/.netrc)",
      "Write(~/.pgpass)",
