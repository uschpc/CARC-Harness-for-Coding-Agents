      "Write(~/.globusonline/**)",
      "Edit(~/.globusonline/**)",
      "Write(~/.docker/config.json)",
      "Edit(~/.docker/config.json)",

      "Bash(crontab -e:*)",
      "Bash(crontab -r:*)",

      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/etc/claude-code/hooks/precheck.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit|Read",
        "hooks": [
          {
            "type": "command",
            "command": "/etc/claude-code/hooks/precheck.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
